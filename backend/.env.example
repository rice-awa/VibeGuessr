# 复制此文件为 .env 并填入实际的 API 密钥
# cp .env.example .env

# === LLM 配置 ===
# openai_compat 或 gemini_native
LLM_PROVIDER=openai_compat
LLM_API_BASE_URL=https://your-llm-proxy.com/v1
LLM_API_KEY=sk-your-llm-api-key-here
LLM_CHAT_MODEL=gemini-2.5-flash
LLM_VISION_MODEL=gemini-2.5-flash
LLM_JSON_MODE=true

# 兼容旧变量，保留给现有部署；如果 LLM_API_KEY 未填写，会回退到 GEMINI_API_KEY
GEMINI_API_BASE_URL=https://your-gemini-proxy.com/v1
GEMINI_API_KEY=sk-your-gemini-api-key-here
LLM_MODEL=gemini-2.5-flash

# === 图片生成配置 ===
IMAGE_API_BASE_URL=https://your-openai-proxy.com/v1
IMAGE_API_KEY=sk-your-image-api-key-here
# 兼容旧图片变量；如果 IMAGE_API_KEY 未填写，会回退到 OPENAI_API_KEY
OPENAI_API_BASE_URL=https://your-openai-proxy.com/v1
OPENAI_API_KEY=sk-your-openai-api-key-here
IMAGE_MODEL=gpt-image-2-all
IMAGE_SIZE=1024x1024
